# ─────────────────────────────────────────────────
# TENDERSHIELD ENVIRONMENT VARIABLES
# .env.local — Copy this to .env.local and fill in your keys
# NEVER commit .env.local to git
# ─────────────────────────────────────────────────

# 1. SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 2. ANTHROPIC — Claude AI (SERVER ONLY — never expose to frontend)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SUPABASE SERVICE ROLE KEY (SERVER ONLY — never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 3. TWILIO — WhatsApp and SMS
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# 4. RESEND — Email
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=alerts@tendershield.gov.in

# 5. MAPBOX — India Map
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# 6. APP SETTINGS
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
JWT_SECRET=generate-a-secure-random-string-here
NODE_ENV=development

# 7. DEMO MODE
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_SHOW_API_SETUP=true

# 8. PINATA — IPFS Document Pinning (real decentralized storage)
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret
PINATA_JWT=your-pinata-jwt
