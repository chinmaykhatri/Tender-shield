#!/bin/sh
# TenderShield — Pre-commit Hook
# Runs type checking and tests before allowing commits.
# Install: copy to .git/hooks/pre-commit and chmod +x

echo "🛡️ TenderShield Pre-Commit Checks..."
echo ""

# 1. TypeScript type checking
echo "📝 Checking TypeScript types..."
npx tsc --noEmit 2>/dev/null
if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors found. Fix them before committing."
  exit 1
fi
echo "✅ Types OK"

# 2. Run tests
echo "🧪 Running tests..."
npx vitest run --reporter=dot 2>/dev/null
if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Fix them before committing."
  exit 1
fi
echo "✅ Tests OK"

# 3. Lint check
echo "🔍 Running linter..."
npx next lint --quiet 2>/dev/null
if [ $? -ne 0 ]; then
  echo "⚠️  Lint warnings found (non-blocking)."
fi
echo "✅ Lint OK"

echo ""
echo "🛡️ All pre-commit checks passed!"
