# ============================================================================
# TenderShield — Fabric Network Secrets Template
# ============================================================================
# Copy this file to .env and replace all CHANGE_THIS values with strong passwords.
# Generate passwords: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER commit the .env file — it is gitignored.
# ============================================================================

# CouchDB State Databases (one password for all CouchDB instances)
COUCHDB_USER=tendershield_admin
COUCHDB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Fabric CA Admin Credentials
FABRIC_CA_ADMIN_USER=admin
FABRIC_CA_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Grafana Monitoring Dashboard
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
