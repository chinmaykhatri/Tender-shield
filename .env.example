# ============================================================================
# TenderShield — Environment Variables Configuration
# ============================================================================
# Copy this file to .env and fill in actual values before running.
# NEVER commit the .env file to version control.
# All secrets should be rotated before production deployment on NIC infra.
# ============================================================================

# ---------------------------------------------------------------------------
# Application Settings
# ---------------------------------------------------------------------------
APP_NAME=TenderShield
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
AI_ENGINE_PORT=8001
FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=your-256-bit-secret-key-change-in-production
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Supabase JWT secret — REQUIRED for production JWT signature verification
# Get from: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-dashboard

# Session cookie signing key — REQUIRED for HMAC-signed auth cookies
# Generate with: openssl rand -base64 32
SESSION_SIGNING_KEY=your-256-bit-session-signing-key-change-in-production

# ---------------------------------------------------------------------------
# Hyperledger Fabric Network
# ---------------------------------------------------------------------------
FABRIC_NETWORK_PROFILE_PATH=./network/connection-profile.yaml
FABRIC_CHANNEL_NAME=tenderchannel
FABRIC_AUDIT_CHANNEL_NAME=auditchannel
FABRIC_CHAINCODE_NAME=tendershield
FABRIC_WALLET_PATH=./wallet
FABRIC_GATEWAY_PEER=peer0.ministry.tendershield.gov.in
FABRIC_GATEWAY_PORT=7051

# Orderer Configuration (Raft — 3 nodes)
FABRIC_ORDERER_ADDRESS=orderer0.orderer.tendershield.gov.in:7050
FABRIC_ORDERER_TLS_CA_PATH=./network/crypto-config/ordererOrganizations/orderer.tendershield.gov.in/orderers/orderer0.orderer.tendershield.gov.in/msp/tlscacerts/tlsca.orderer.tendershield.gov.in-cert.pem

# Organization MSP IDs
MINISTRY_ORG_MSP=MinistryOrgMSP
BIDDER_ORG_MSP=BidderOrgMSP
AUDITOR_ORG_MSP=AuditorOrgMSP
NIC_ORG_MSP=NICOrgMSP

# ---------------------------------------------------------------------------
# PostgreSQL Database (Off-chain metadata)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tendershield_db
POSTGRES_USER=tendershield_admin
POSTGRES_PASSWORD=change-this-in-production-ts2025
DATABASE_URL=postgresql://tendershield_admin:change-this-in-production-ts2025@localhost:5432/tendershield_db

# ---------------------------------------------------------------------------
# Redis Cache (Session, JWT Blacklist, Rate Limiting)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------------------
# Apache Kafka (Event Streaming)
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TENDER_EVENTS_TOPIC=tender-events
KAFKA_BID_EVENTS_TOPIC=bid-events
KAFKA_AI_ALERTS_TOPIC=ai-alerts
KAFKA_AUDIT_EVENTS_TOPIC=audit-events
KAFKA_BLOCKCHAIN_FEED_TOPIC=blockchain-feed
KAFKA_CONSUMER_GROUP_BACKEND=tendershield-backend
KAFKA_CONSUMER_GROUP_AI=tendershield-ai-engine

# ---------------------------------------------------------------------------
# IPFS + MinIO (Document Storage)
# ---------------------------------------------------------------------------
IPFS_GATEWAY_URL=http://localhost:5001
IPFS_API_URL=http://localhost:5001/api/v0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=tendershield-minio-key
MINIO_SECRET_KEY=change-this-minio-secret
MINIO_BUCKET=tendershield-documents

# ---------------------------------------------------------------------------
# Indian Government API Integrations (Sandbox/Demo Mode)
# ---------------------------------------------------------------------------

# Aadhaar eKYC (UIDAI Sandbox)
AADHAAR_API_BASE_URL=https://stage1.uidai.gov.in/onlineekyc/getAuth
AADHAAR_API_KEY=your-uidai-sandbox-api-key
AADHAAR_API_SECRET=your-uidai-sandbox-secret
AADHAAR_SANDBOX_MODE=true

# GeM (Government e-Marketplace) API
GEM_API_BASE_URL=https://api.gem.gov.in/v1
GEM_API_KEY=your-gem-api-key
GEM_API_SECRET=your-gem-api-secret
GEM_SANDBOX_MODE=true

# PFMS (Public Financial Management System) Payment Integration
PFMS_API_BASE_URL=https://pfms.nic.in/api/v1
PFMS_API_KEY=your-pfms-api-key
PFMS_SANDBOX_MODE=true

# GST Verification API
GST_API_BASE_URL=https://api.gst.gov.in/taxpayerapi/v2
GST_API_KEY=your-gst-api-key

# PAN Verification API (NSDL/UTIITSL)
PAN_VERIFICATION_API_URL=https://verify.pan.gov.in/api/v1
PAN_API_KEY=your-pan-api-key

# DPIIT Startup Registration Verification
DPIIT_API_BASE_URL=https://api.startupindia.gov.in/v1
DPIIT_API_KEY=your-dpiit-api-key

# ---------------------------------------------------------------------------
# AI Fraud Detection Engine
# ---------------------------------------------------------------------------
AI_MODEL_PATH=./ai_engine/models/
AI_RISK_THRESHOLD_LOW=25
AI_RISK_THRESHOLD_MEDIUM=50
AI_RISK_THRESHOLD_HIGH=75
AI_RISK_THRESHOLD_CRITICAL=90
AI_AUTO_FREEZE_ENABLED=true
AI_AUTO_FREEZE_THRESHOLD=75

# ---------------------------------------------------------------------------
# Monitoring (Prometheus + Grafana)
# ---------------------------------------------------------------------------
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=tendershield_grafana_2025

# ---------------------------------------------------------------------------
# CouchDB (Fabric State Database)
# ---------------------------------------------------------------------------
COUCHDB_USER=tendershield_admin
COUCHDB_PASSWORD=tendershield_couchdb_2025

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=./logs/tendershield.log

# ---------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Request-ID
