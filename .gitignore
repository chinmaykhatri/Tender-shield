# ============================================
# TenderShield — Git Ignore
# ============================================

# Dependencies
node_modules/
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Build output
.next/
dist/
build/
*.egg

# Environment files (NEVER commit secrets)
.env
.env.*
!.env.example
!.env.local.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Docker volumes / local data
pgdata/
redisdata/
docker-data/
tendershield_ledger.db

# Logs
*.log
npm-debug.log*
temp_frontend_log.txt

# Testing
.pytest_cache/
coverage/
.coverage

# Build info
tsconfig.tsbuildinfo

# Misc
*.bak
*.tmp

